{
  "expo": {
    "name": "EcoSnap",
    "slug": "ecosnap",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/leaf-icon.png",
    "scheme": "ecosnap",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/leaf-icon.png",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "EcoSnap uses your current GPS location to center the live impact map and show nearby hotspots."
      }
    },
    "android": {
      "icon": "./assets/images/leaf-icon.png",
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.ecosnap",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/leaf-icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-font",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "EcoSnap uses your current GPS location to center the live impact map and show nearby hotspots."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
